CODEXPORT_RELAY_LISTEN_HOST=0.0.0.0
CODEXPORT_RELAY_PORT=8080
CODEXPORT_RELAY_PUBLISHED_PORT=8080
CODEXPORT_RELAY_PUBLIC_BASE_URL=https://codexport.smarteffi.net
CODEXPORT_RELAY_STORAGE_PATH=/var/lib/codexport-relay
CODEXPORT_RELAY_LOG_LEVEL=info
CODEXPORT_RELAY_TLS_MODE=reverse-proxy
# Required when coturn is enabled. Must match coturn static-auth-secret.
# Do not commit production secret values.
# CODEXPORT_RELAY_TURN_SHARED_SECRET=change-me
# Optional; defaults derive from CODEXPORT_RELAY_PUBLIC_BASE_URL.
# CODEXPORT_RELAY_STUN_URLS=stun:codexport.smarteffi.net:3478
# CODEXPORT_RELAY_TURN_URLS=turn:codexport.smarteffi.net:3478?transport=udp turn:codexport.smarteffi.net:3478?transport=tcp
# CODEXPORT_RELAY_TURN_TTL_SECONDS=600
